.cursorrules

# 数据和日志
# Use /data/* (not /data/) so Sprint 2 can whitelist a single placeholder
# inside this directory; per-stock journal logs stay ignored explicitly.
/data/*
logs/
reports/

# Sprint 2 — decision journal entries are user-private; never commit them.
# Track only the placeholder so first-time users have a slot; the per-stock
# markdown logs stay local.
!/data/decision_journals/
/data/decision_journals/*
!/data/decision_journals/.gitkeep

# Sprint 3 — qlib bulk data is GB-scale and downloaded via
# scripts/setup_qlib_data.sh; never commit the binary payload.  We keep
# the dir slot via a .gitkeep so the first run finds the path.
!/data/qlib/
/data/qlib/*
!/data/qlib/.gitkeep
# Sprint 3 — LightGBM artifacts are per-user, weekly, uploaded to a
# GitHub Release by the qlib-retrain workflow instead of git history.
!/data/quant_models/
/data/quant_models/*
!/data/quant_models/.gitkeep
# Sprint 4 — committee checkpoint SQLite snapshots are per-task / per-user
# and only meaningful for that user's machine; keep the dir slot, ignore
# the .db files (already covered by the global *.db rule below).
!/data/committee_checkpoints/
/data/committee_checkpoints/*
!/data/committee_checkpoints/.gitkeep
*.db
*.sqlite
*.sqlite3

# 系统文件
.DS_Store
Thumbs.db

# 测试
.pytest_cache/
.coverage
htmlcov/

local/

run.sh

verify_*.py

# ignore Claude workspace artifacts, but keep shared repo skills versioned
.claude/*
!.claude/skills/
!.claude/skills/**

# ignore static files
static/
/apps/dsa-desktop/dist/
/apps/dsa-desktop/node_modules/

# server runtime log written by 'python main.py --webui-only'
webui.log
